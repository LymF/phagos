// =============================================================================
// PHAGOS — PHAge Genome One-Stop analysis
// Nextflow configuration
// =============================================================================

manifest {
    name        = 'phagos'
    description = 'PHAGOS: PHAge Genome One-Stop analysis — reads → assembly → annotation → comparative genomics → phylogeny'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}

// ── Default parameters (overridden by -params-file config.yaml) ────────────
params {
    sample         = "phage"
    reads_r1       = null
    reads_r2       = null
    outdir         = "results"
    phage_name     = "Query phage"
    host           = ""
    threads        = 8
    max_memory     = "64.GB"
    max_cpus       = 16

    pharokka_db    = null
    phold_db       = null
    checkv_db      = null
    taxmyphage_db  = null
    vibrant_db     = null
    msl            = null

    ncbi_email     = null
    ncbi_api_key   = ""

    fastp_min_qual    = 20
    fastp_min_len     = 50
    phylo_markers     = "terminase large subunit,major capsid protein"
    clinker_top_n     = 6
    clinker_identity  = 0.3

    skip_vibrant     = false
    skip_comparative = false
    skip_phylo       = false
    skip_clinker     = false
}

// ── Per-process container + resource definitions ────────────────────────────
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withName: 'FASTP' {
        container = 'quay.io/biocontainers/fastp:1.0.0--heae3180_0'
        cpus      = params.threads
        memory    = '8.GB'
    }
    withName: 'UNICYCLER' {
        container = 'quay.io/biocontainers/unicycler:0.5.1--py312hdcc493e_5'
        cpus      = params.threads
        memory    = '32.GB'
    }
    withName: 'CHECKV' {
        container = 'quay.io/biocontainers/checkv:1.0.3--pyhdfd78af_0'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'BWA_INDEX|BWA_MEM|SAMTOOLS_SORT|SAMTOOLS_DEPTH' {
        container = 'quay.io/biocontainers/bwa-mem2:2.3--he70b90d_0'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'SAMTOOLS_SORT|SAMTOOLS_INDEX|SAMTOOLS_DEPTH' {
        container = 'quay.io/biocontainers/samtools:1.23.1--ha83d96e_0'
    }
    withName: 'TAXMYPHAGE' {
        container = 'quay.io/biocontainers/taxmyphage:0.3.0--pyhdfd78af_0'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'PHAROKKA' {
        container = 'quay.io/biocontainers/pharokka:1.9.1--pyhdfd78af_1'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'PHOLD' {
        container = 'quay.io/biocontainers/phold:1.2.5--pyhdfd78af_0'
        cpus      = params.threads
        memory    = '32.GB'   // structural annotation — ESM requires more RAM
    }
    withName: 'VIBRANT' {
        container = 'quay.io/biocontainers/vibrant:1.2.1--hdfd78af_4'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'COMPARATIVE_PREP' {
        container = 'quay.io/biocontainers/blast:2.16.0--h66d330f_5'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'PHYLO_PREP' {
        // Python + biopython — shares the custom genome_map image
        container = 'ghcr.io/lymf/vapor-genome-map:1.0'
        cpus      = 4
        memory    = '8.GB'
    }
    withName: 'MAFFT' {
        container = 'quay.io/biocontainers/mafft:7.525--h031d066_1'
        cpus      = params.threads
        memory    = '8.GB'
    }
    withName: 'TRIMAL' {
        container = 'quay.io/biocontainers/trimal:1.5.0--h9948957_2'
        cpus      = 1
        memory    = '4.GB'
    }
    withName: 'IQTREE' {
        container = 'quay.io/biocontainers/iqtree:2.3.6--h503566f_1'
        cpus      = params.threads
        memory    = '16.GB'
    }
    withName: 'CLINKER' {
        container = 'quay.io/biocontainers/clinker-py:0.0.29--pyhdfd78af_0'
        cpus      = params.threads
        memory    = '8.GB'
    }
    withName: 'GENOME_MAP' {
        container = 'ghcr.io/lymf/vapor-genome-map:1.0'
        cpus      = 2
        memory    = '4.GB'
    }
}

// ── Profiles ────────────────────────────────────────────────────────────────
profiles {

    // Container profiles (pick one)
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.runOptions = "--no-home"
    }

    docker {
        docker.enabled     = true
        docker.runOptions  = "-u \$(id -u):\$(id -g)"
    }

    conda {
        conda.enabled    = true
        conda.useMamba   = true
    }

    // Executor profiles (pick one)
    local {
        executor {
            name      = 'local'
            cpus      = 40
            memory    = '120 GB'
        }
    }

    slurm {
        executor {
            name       = 'slurm'
            queueSize  = 20
            submitRateLimit = '10/1min'
        }
        process {
            queue  = 'batch'
            time   = '24h'
        }
    }
}

// ── Output timestamps and trace ─────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.tsv"
}
